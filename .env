APP_NAME=Camera Monitoring System
APP_ENV=local
API_PREFIX=/api/v1

MONGO_URI=mongodb://mongo:27017
MONGO_DB_NAME=camera_monitoring

# MediaMTX integration
# Internal API URL (container-to-container) for status polling
MEDIAMTX_API_URL=http://mediamtx:9997
# Public-facing HLS URL (browser accesses this directly for video)
MEDIAMTX_HLS_BASE_URL=http://localhost:8888
# How often to poll MediaMTX for camera status (seconds)
MEDIAMTX_POLL_INTERVAL_SECONDS=5

DEFAULT_TARGET_FPS=10
DEFAULT_DISPLAY_FPS=5
MAX_DISPLAY_FPS=15

CPU_ALERT_THRESHOLD=90
MEMORY_ALERT_THRESHOLD=85
RESOURCE_ALERT_DURATION_SECONDS=30
ALERT_COOLDOWN_SECONDS=60

TELEGRAM_ENABLED=true
ALERT_TELEGRAM_TOKEN=8316269633:AAGfXVLPfVIcDiVIh6XY6ff7oocETuwbfBo
TELEGRAM_CHAT_ID=1435451680
